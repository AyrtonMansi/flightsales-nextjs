# --- Anthropic (required) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Supabase (required) ---  Project Settings -> API
SUPABASE_URL=https://YOURPROJECT.supabase.co
SUPABASE_SERVICE_KEY=eyJ...           # service_role key. SERVER-SIDE ONLY.

# --- Cron protection (required) ---
CRON_SECRET=generate-a-long-random-string

# --- Outbound email for RED actions (required to actually send) ---
# Gmail/Workspace: host smtp.gmail.com, port 587, user = your address, pass = an App Password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@yourdomain.com
SMTP_PASS=your-app-password
SMTP_FROM=you@yourdomain.com

# --- Push notification when approval is needed (optional but recommended) ---
# ntfy: set to https://ntfy.sh/your-unique-topic and subscribe on your phone.
# Or a Slack/Discord webhook URL.
NOTIFY_WEBHOOK_URL=
DASHBOARD_URL=https://your-deploy.vercel.app

# --- Google read access for inbox/calendar watching (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
