# ============================================
# Public Supabase credentials — required for all reads/writes.
# Available in Supabase project settings → API.
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...

# ============================================
# Server-only Supabase service role — required for transactional email
# routes (/api/enquiries, /api/contact, /api/admin/notify) so they can
# insert notifications + email_log rows on behalf of any user. Keep this
# OFF the client. Available in Supabase project settings → API.
# ============================================
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...

# ============================================
# Resend — transactional email provider.
# Sign up at https://resend.com (free tier covers 3k/month).
# 1. Add your sending domain (e.g. flightsales.com.au)
# 2. Verify DNS (SPF + DKIM + return-path)
# 3. Generate an API key
# ============================================
RESEND_API_KEY=re_...
EMAIL_FROM="FlightSales <noreply@flightsales.com.au>"
EMAIL_REPLY_TO=support@flightsales.com.au
EMAIL_BCC_ADMIN=ops@flightsales.com.au

# Optional: shared secret for server-to-server email API calls.
# Leave unset to keep /api/email's anon-only template gate.
# INTERNAL_API_TOKEN=

# Optional: site origin used by sitemap, OG cards, and email links.
# Defaults to https://flightsales.com.au if unset.
# NEXT_PUBLIC_SITE_URL=https://flightsales.com.au
